@model RR.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - Banco Financiero</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0a1929 0%, #1a2b3c 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        /* Fondo con elementos financieros sutiles */
        body::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background-image:
                repeating-linear-gradient(45deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 2px, transparent 2px, transparent 4px),
                radial-gradient(circle at 20% 30%, rgba(0,100,200,0.1) 0%, transparent 30%),
                radial-gradient(circle at 80% 70%, rgba(0,200,150,0.1) 0%, transparent 30%);
            pointer-events: none;
        }

        .login-container {
            background: rgba(18, 30, 45, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 50px 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 255, 0.2);
            position: relative;
            z-index: 10;
            animation: slideUp 0.5s ease-out;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Línea decorativa superior */
        .login-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: linear-gradient(90deg, #00c6ff, #0072ff);
            border-radius: 0 0 4px 4px;
        }

        .bank-logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .bank-logo i {
            font-size: 50px;
            color: #00c6ff;
            background: linear-gradient(135deg, #00c6ff, #0072ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .bank-logo h1 {
            color: #fff;
            font-size: 28px;
            font-weight: 600;
            margin: 15px 0 5px;
            letter-spacing: 1px;
        }

        .bank-logo p {
            color: #8a9bb5;
            font-size: 14px;
            font-weight: 300;
        }

        .form-group {
            margin-bottom: 25px;
            position: relative;
        }

        .form-group label {
            display: block;
            color: #b8c7de;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #4a6782;
            font-size: 16px;
            transition: color 0.3s ease;
        }

        .input-wrapper input {
            width: 100%;
            padding: 15px 15px 15px 45px;
            background: rgba(10, 25, 45, 0.8);
            border: 2px solid #1e3a5f;
            border-radius: 12px;
            color: #fff;
            font-size: 15px;
            transition: all 0.3s ease;
        }

        .input-wrapper input:focus {
            outline: none;
            border-color: #0072ff;
            box-shadow: 0 0 0 3px rgba(0, 114, 255, 0.2);
        }

        .input-wrapper input:focus + i {
            color: #0072ff;
        }

        .input-wrapper input::placeholder {
            color: #4a6782;
            font-size: 14px;
        }

        .forgot-link {
            text-align: right;
            margin-top: 8px;
        }

        .forgot-link a {
            color: #6b8cae;
            font-size: 13px;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .forgot-link a:hover {
            color: #00c6ff;
        }

        .btn-login {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #0072ff, #00c6ff);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 15px;
            position: relative;
            overflow: hidden;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 114, 255, 0.5);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn-login:active::after {
            width: 300px;
            height: 300px;
        }

        .security-info {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #1e3a5f;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            color: #6b8cae;
            font-size: 12px;
        }

        .security-info i {
            color: #00c6ff;
            font-size: 14px;
        }

        .validation-summary {
            background: rgba(255, 68, 68, 0.1);
            border-left: 4px solid #ff4444;
            padding: 12px;
            margin-bottom: 20px;
            border-radius: 8px;
            color: #ff6b6b;
            font-size: 14px;
        }

        .validation-summary ul {
            list-style: none;
            margin-left: 0;
            padding-left: 0;
        }

        .field-validation-error {
            color: #ff6b6b;
            font-size: 12px;
            margin-top: 5px;
            display: block;
        }

        .digital-badge {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 15px;
        }

        .digital-badge span {
            color: #4a6782;
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .digital-badge i {
            font-size: 12px;
            color: #00c6ff;
        }

        .live-indicator {
            position: absolute;
            top: 20px;
            right: 20px;
            color: #00ff88;
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 5px;
            background: rgba(0, 255, 136, 0.1);
            padding: 5px 10px;
            border-radius: 20px;
        }

        .live-indicator i {
            font-size: 8px;
            animation: pulse 1.5s infinite;
        }

        @@keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.3; }
            100% { opacity: 1; }
        }
    </style>
</head>
<body>
    <div class="live-indicator">
        <i class="fas fa-circle"></i>
        <span>Conexión segura • Banca en línea</span>
    </div>

    <div class="login-container">
        <div class="bank-logo">
            <i class="fas fa-university"></i>
            <h1>BANCO FINANCIERO</h1>
            <p>Plataforma Corporativa</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary">
                @Html.ValidationSummary(true)
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div style="background: rgba(0, 255, 0, 0.1); border-left: 4px solid #00ff88; padding: 12px; margin-bottom: 20px; border-radius: 8px; color: #00ff88;">
                @TempData["Success"]
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="form-group">
                <label asp-for="Usuario">USUARIO CORPORATIVO</label>
                <div class="input-wrapper">
                    <i class="fas fa-user"></i>
                    <input asp-for="Usuario" placeholder="Ingrese su usuario" />
                </div>
                <span asp-validation-for="Usuario" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Contraseña">CONTRASEÑA</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock"></i>
                    <input asp-for="Contraseña" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Contraseña" class="field-validation-error"></span>
                <div class="forgot-link">
                    <a href="#"><i class="fas fa-shield-alt"></i> Contactar soporte</a>
                </div>
            </div>

            <button type="submit" class="btn-login">
                INICIAR SESIÓN <i class="fas fa-arrow-right" style="margin-left: 10px;"></i>
            </button>
        </form>

        <div class="security-info">
            <i class="fas fa-lock"></i>
            <span>Transacciones seguras con encriptación 256-bit</span>
        </div>

        <div class="digital-badge">
            <span><i class="fas fa-check-circle"></i> Verificado</span>
            <span><i class="fas fa-shield-alt"></i> Protegido</span>
            <span><i class="fas fa-clock"></i> 24/7</span>
        </div>
    </div>
</body>
</html>