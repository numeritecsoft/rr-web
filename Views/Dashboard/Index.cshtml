@model DashboardView2Model

@{
    ViewData["Title"] = "Dashboard de Reportes Financieros";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0a1929 0%, #1a2b3c 100%);
            min-height: 100vh;
        }

        .layout {
            display: flex;
            min-height: 100vh;
        }

        /* Menú lateral izquierdo */
        .left-menu {
            width: 280px;
            background: rgba(10, 25, 45, 0.95);
            backdrop-filter: blur(10px);
            border-right: 1px solid rgba(0, 255, 255, 0.2);
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            padding: 25px 20px;
            box-shadow: 5px 0 30px rgba(0, 0, 0, 0.5);
            z-index: 1000;
            transition: transform 0.3s ease;
        }

            .left-menu::-webkit-scrollbar {
                width: 5px;
            }

            .left-menu::-webkit-scrollbar-track {
                background: #1e3a5f;
            }

            .left-menu::-webkit-scrollbar-thumb {
                background: #0072ff;
                border-radius: 5px;
            }

        /* Contenido principal */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 20px;
            transition: margin-left 0.3s ease;
        }

        /* Perfil de usuario */
        .user-profile {
            text-align: center;
            padding-bottom: 25px;
            border-bottom: 2px solid #1e3a5f;
            margin-bottom: 25px;
        }

        .user-avatar {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #0072ff, #00c6ff);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            border: 3px solid #00c6ff;
        }

            .user-avatar i {
                font-size: 40px;
                color: white;
            }

        .user-name {
            color: #fff;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .user-role {
            color: #00c6ff;
            font-size: 13px;
            background: rgba(0, 198, 255, 0.1);
            padding: 4px 12px;
            border-radius: 20px;
            display: inline-block;
        }

        /* Logo del banco */
        .bank-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 15px 25px 15px;
            border-bottom: 2px solid #1e3a5f;
            margin-bottom: 20px;
        }

            .bank-logo i {
                font-size: 32px;
                color: #00c6ff;
                background: linear-gradient(135deg, #00c6ff, #0072ff);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .bank-logo span {
                color: #fff;
                font-size: 18px;
                font-weight: 600;
            }

            .bank-logo small {
                color: #00c6ff;
                font-size: 10px;
                display: block;
                margin-top: 2px;
            }

        /* Menú de navegación */
        .menu-section {
            margin-bottom: 30px;
        }

        .menu-title {
            color: #8a9bb5;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
            padding-left: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .menu-title i {
                color: #00c6ff;
                font-size: 14px;
            }

        .menu-items {
            list-style: none;
        }

        .menu-item {
            margin-bottom: 5px;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            color: #b8c7de;
            text-decoration: none;
            border-radius: 12px;
            transition: all 0.3s ease;
            position: relative;
        }

            .menu-link:hover {
                background: rgba(0, 114, 255, 0.2);
                color: #fff;
                transform: translateX(5px);
            }

            .menu-link.active {
                background: linear-gradient(135deg, #0072ff, #00c6ff);
                color: white;
                box-shadow: 0 5px 15px rgba(0, 114, 255, 0.3);
            }

            .menu-link i {
                width: 20px;
                font-size: 16px;
            }

        .menu-badge {
            margin-left: auto;
            background: rgba(255, 255, 255, 0.2);
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11px;
            color: white;
        }

        /* Acciones rápidas */
        .quick-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 15px;
            padding: 0 10px;
        }

        .quick-action-btn {
            background: #1e3a5f;
            border: none;
            border-radius: 12px;
            padding: 15px 10px;
            color: #b8c7de;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .quick-action-btn:hover {
                background: #0072ff;
                color: white;
                transform: translateY(-3px);
            }

            .quick-action-btn i {
                font-size: 20px;
            }

            .quick-action-btn span {
                font-size: 11px;
                font-weight: 500;
            }

        /* Filtros rápidos */
        .filters-container {
            padding: 0 10px;
        }

        .filter-tag {
            display: inline-block;
            padding: 6px 12px;
            background: #1e3a5f;
            color: #b8c7de;
            border-radius: 20px;
            font-size: 12px;
            margin: 0 5px 5px 0;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .filter-tag:hover {
                background: #0072ff;
                color: white;
            }

            .filter-tag i {
                margin-right: 5px;
                font-size: 10px;
            }

        /* Estadísticas rápidas */
        .mini-stats {
            background: #1e3a5f;
            border-radius: 12px;
            padding: 15px;
            margin: 15px 10px;
        }

        .mini-stat-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid #2a4a7a;
        }

            .mini-stat-item:last-child {
                border-bottom: none;
            }

        .mini-stat-label {
            color: #8a9bb5;
            font-size: 13px;
        }

        .mini-stat-value {
            color: #00c6ff;
            font-weight: 600;
        }

        /* Notificaciones */
        .notifications-container {
            padding: 0 10px;
        }

        .notification-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            background: #1e3a5f;
            border-radius: 12px;
            margin-bottom: 10px;
            transition: all 0.3s ease;
        }

            .notification-item:hover {
                background: #2a4a7a;
                transform: translateX(5px);
            }

        .notification-icon {
            width: 35px;
            height: 35px;
            background: rgba(0, 198, 255, 0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #00c6ff;
        }

        .notification-content {
            flex: 1;
        }

        .notification-text {
            color: #fff;
            font-size: 13px;
            margin-bottom: 3px;
        }

        .notification-time {
            color: #6b8cae;
            font-size: 10px;
        }

        /* Botón de colapso */
        .menu-toggle {
            position: fixed;
            left: 290px;
            top: 20px;
            width: 30px;
            height: 30px;
            background: #1e3a5f;
            border: none;
            border-radius: 8px;
            color: #00c6ff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1001;
            transition: all 0.3s ease;
        }

            .menu-toggle:hover {
                background: #0072ff;
                color: white;
            }

            .menu-toggle.collapsed {
                left: 20px;
            }

        /* Estado colapsado */
        .layout.collapsed .left-menu {
            transform: translateX(-100%);
        }

        .layout.collapsed .main-content {
            margin-left: 0;
        }

        .layout.collapsed .menu-toggle {
            left: 20px;
        }

        /* Dashboard styles (mantener todos los estilos anteriores del dashboard) */
        .dashboard-container {
            max-width: 1600px;
            margin: 0 auto;
        }

        .dashboard-header {
            background: rgba(18, 30, 45, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 25px 30px;
            margin-bottom: 25px;
            border: 1px solid rgba(0, 255, 255, 0.1);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .header-title {
            display: flex;
            align-items: center;
            gap: 20px;
        }

            .header-title i {
                font-size: 40px;
                color: #00c6ff;
                background: linear-gradient(135deg, #00c6ff, #0072ff);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .header-title h1 {
                color: #fff;
                font-size: 28px;
                font-weight: 600;
            }

            .header-title span {
                color: #00c6ff;
                font-size: 14px;
                margin-left: 15px;
                padding: 5px 12px;
                background: rgba(0, 198, 255, 0.1);
                border-radius: 20px;
            }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-top: 25px;
        }

        .stat-card {
            background: rgba(10, 25, 45, 0.8);
            border-radius: 15px;
            padding: 20px;
            border: 1px solid #1e3a5f;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #0072ff, #00c6ff);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .stat-icon i {
                font-size: 24px;
                color: white;
            }

        .stat-info h3 {
            color: #8a9bb5;
            font-size: 14px;
            font-weight: 400;
        }

        .stat-info p {
            color: #fff;
            font-size: 28px;
            font-weight: 600;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            margin-bottom: 25px;
        }

        .grid-item {
            background: rgba(18, 30, 45, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            border: 1px solid rgba(0, 255, 255, 0.1);
        }

            .grid-item.full-width {
                grid-column: 1 / -1;
            }

        .item-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #1e3a5f;
        }

            .item-header i {
                font-size: 24px;
                color: #00c6ff;
            }

            .item-header h2 {
                color: #fff;
                font-size: 18px;
                font-weight: 500;
            }

            .item-header span {
                margin-left: auto;
                color: #00c6ff;
                font-size: 14px;
                background: rgba(0, 198, 255, 0.1);
                padding: 4px 12px;
                border-radius: 20px;
            }

        .table-responsive {
            overflow-x: auto;
        }

        .stats-table {
            width: 100%;
            border-collapse: collapse;
        }

            .stats-table th {
                text-align: left;
                padding: 12px 10px;
                color: #8a9bb5;
                font-weight: 500;
                font-size: 12px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border-bottom: 1px solid #1e3a5f;
            }

            .stats-table td {
                padding: 12px 10px;
                color: #fff;
                border-bottom: 1px solid rgba(30, 58, 95, 0.5);
            }

            .stats-table tr:hover td {
                background: rgba(0, 114, 255, 0.1);
            }

        .rank-badge {
            display: inline-block;
            width: 24px;
            height: 24px;
            background: #1e3a5f;
            border-radius: 6px;
            text-align: center;
            line-height: 24px;
            color: #00c6ff;
            font-weight: 600;
            font-size: 12px;
        }

        .percentage-bar {
            width: 80px;
            height: 6px;
            background: #1e3a5f;
            border-radius: 3px;
            overflow: hidden;
            display: inline-block;
            margin-left: 10px;
        }

        .percentage-fill {
            height: 100%;
            background: linear-gradient(90deg, #0072ff, #00c6ff);
            border-radius: 3px;
        }

        .text-highlight {
            color: #00c6ff;
            font-weight: 600;
        }

        .details-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

            .details-table th {
                background: #0a1929;
                padding: 15px 12px;
                color: #8a9bb5;
                font-weight: 500;
                text-align: left;
                font-size: 12px;
                text-transform: uppercase;
                border-bottom: 2px solid #1e3a5f;
            }

            .details-table td {
                padding: 12px;
                color: #fff;
                border-bottom: 1px solid #1e3a5f;
            }

            .details-table tr:hover td {
                background: rgba(0, 114, 255, 0.1);
            }

        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 500;
        }

        .badge-blue {
            background: rgba(0, 114, 255, 0.2);
            color: #00c6ff;
        }

        .badge-purple {
            background: rgba(156, 39, 176, 0.2);
            color: #ba68c8;
        }

        .badge-green {
            background: rgba(76, 175, 80, 0.2);
            color: #81c784;
        }

        .footer-note {
            margin-top: 20px;
            text-align: center;
            color: #4a6782;
            font-size: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
        }

        .live-indicator {
            color: #00ff88;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .live-indicator i {
                font-size: 8px;
                animation: pulse 1.5s infinite;
            }

        @@keyframes pulse {
            0%

        {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }

        100% {
            opacity: 1;
        }

        }
    </style>
</head>
<body>
    <div class="layout" id="layout">
        <!-- Botón para colapsar/expandir menú -->
        <button class="menu-toggle" id="menuToggle">
            <i class="fas fa-chevron-left"></i>
        </button>

        <!-- Menú lateral izquierdo -->
        <div class="left-menu">
            <!-- Logo del banco -->
            <div class="bank-logo">
                <i class="fas fa-university"></i>
                <div>
                    <span>BANCO FINANCIERO</span>
                    <small>Centro de Control</small>
                </div>
            </div>

            <!-- Perfil de usuario -->
            <div class="user-profile">
                <div class="user-avatar">
                    <i class="fas fa-user-tie"></i>
                </div>
                <div class="user-name">Juan Carlos Pérez</div>
                <div class="user-role">Administrador de Reportes</div>
            </div>

            <!-- Navegación principal -->
            <div class="menu-section">
                <div class="menu-title">
                    <i class="fas fa-compass"></i>
                    <span>Navegación</span>
                </div>
                <ul class="menu-items">
                    <li class="menu-item">
                        <a href="#" class="menu-link active">
                            <i class="fas fa-chart-pie"></i>
                            <span>Dashboard</span>
                            <span class="menu-badge">326</span>
                        </a>
                    </li>
                    <li class="menu-item">
                        <a href="#" class="menu-link">
                            <i class="fas fa-file-alt"></i>
                            <span>Reportes</span>
                            <span class="menu-badge">12</span>
                        </a>
                    </li>
                    <li class="menu-item">
                        <a href="#" class="menu-link">
                            <i class="fas fa-building"></i>
                            <span>Autoridades</span>
                            <span class="menu-badge">10</span>
                        </a>
                    </li>
                    <li class="menu-item">
                        <a href="#" class="menu-link">
                            <i class="fas fa-calendar-alt"></i>
                            <span>Calendario</span>
                            <span class="menu-badge">5</span>
                        </a>
                    </li>
                    <li class="menu-item">
                        <a href="#" class="menu-link">
                            <i class="fas fa-users"></i>
                            <span>Directores</span>
                            <span class="menu-badge">16</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Acciones rápidas -->
            <div class="menu-section">
                <div class="menu-title">
                    <i class="fas fa-bolt"></i>
                    <span>Acciones rápidas</span>
                </div>
                <div class="quick-actions">
                    <button class="quick-action-btn">
                        <i class="fas fa-plus-circle"></i>
                        <span>Nuevo Reporte</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-download"></i>
                        <span>Exportar</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-print"></i>
                        <span>Imprimir</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-filter"></i>
                        <span>Filtros</span>
                    </button>
                </div>
            </div>

            <!-- Filtros rápidos -->
            <div class="menu-section">
                <div class="menu-title">
                    <i class="fas fa-tags"></i>
                    <span>Filtros populares</span>
                </div>
                <div class="filters-container">
                    <span class="filter-tag"><i class="fas fa-university"></i> CNBV</span>
                    <span class="filter-tag"><i class="fas fa-university"></i> BANXICO</span>
                    <span class="filter-tag"><i class="fas fa-calendar"></i> Mensual</span>
                    <span class="filter-tag"><i class="fas fa-calendar"></i> Diaria</span>
                    <span class="filter-tag"><i class="fas fa-user"></i> Juan Rodriguez</span>
                    <span class="filter-tag"><i class="fas fa-tag"></i> Operativo</span>
                </div>
            </div>

            <!-- Estadísticas rápidas -->
            <div class="menu-section">
                <div class="menu-title">
                    <i class="fas fa-chart-line"></i>
                    <span>Resumen rápido</span>
                </div>
                <div class="mini-stats">
                    <div class="mini-stat-item">
                        <span class="mini-stat-label">Reportes este mes</span>
                        <span class="mini-stat-value">+24</span>
                    </div>
                    <div class="mini-stat-item">
                        <span class="mini-stat-label">Pendientes</span>
                        <span class="mini-stat-value">8</span>
                    </div>
                    <div class="mini-stat-item">
                        <span class="mini-stat-label">Vencidos</span>
                        <span class="mini-stat-value" style="color: #ff4444;">3</span>
                    </div>
                    <div class="mini-stat-item">
                        <span class="mini-stat-label">Completados</span>
                        <span class="mini-stat-value" style="color: #00ff88;">291</span>
                    </div>
                </div>
            </div>

            <!-- Notificaciones -->
            <div class="menu-section">
                <div class="menu-title">
                    <i class="fas fa-bell"></i>
                    <span>Notificaciones</span>
                    <span class="menu-badge" style="margin-left: auto;">3</span>
                </div>
                <div class="notifications-container">
                    <div class="notification-item">
                        <div class="notification-icon">
                            <i class="fas fa-file"></i>
                        </div>
                        <div class="notification-content">
                            <div class="notification-text">Reporte ACLME por vencer</div>
                            <div class="notification-time">Hace 5 minutos</div>
                        </div>
                    </div>
                    <div class="notification-item">
                        <div class="notification-icon">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <div class="notification-content">
                            <div class="notification-text">Reporte mensual completado</div>
                            <div class="notification-time">Hace 2 horas</div>
                        </div>
                    </div>
                    <div class="notification-item">
                        <div class="notification-icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <div class="notification-content">
                            <div class="notification-text">Actualización de formato BANXICO</div>
                            <div class="notification-time">Hace 1 día</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cerrar sesión -->
            <div class="menu-section" style="margin-top: auto; padding-top: 20px;">
                <a href="#" class="menu-link" style="color: #ff6b6b;">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Cerrar sesión</span>
                </a>
            </div>
        </div>

        <!-- Contenido principal (igual que antes) -->
        <div class="main-content">
            <div class="dashboard-container">
                <!-- Header -->
                <div class="dashboard-header">
                    <div class="header-title">
                        <i class="fas fa-chart-pie"></i>
                        <h1>Centro de Control de Reportes Financieros</h1>
                        <span>Actualizado en tiempo real</span>
                    </div>

                    <div class="stats-row">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-file-alt"></i>
                            </div>
                            <div class="stat-info">
                                <h3>Total Reportes</h3>
                                <p>@Model.TotalReportes</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-building"></i>
                            </div>
                            <div class="stat-info">
                                <h3>Autoridades</h3>
                                <p>@Model.Autoridades.Count</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-calendar-alt"></i>
                            </div>
                            <div class="stat-info">
                                <h3>Frecuencias</h3>
                                <p>@Model.Frecuencias.Count</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="stat-info">
                                <h3>Directores</h3>
                                <p>@Model.Directores.Count</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Grid de tablas estadísticas -->
                <div class="dashboard-grid">
                    <!-- Autoridades -->
                    <div class="grid-item">
                        <div class="item-header">
                            <i class="fas fa-university"></i>
                            <h2>Distribución por Autoridad</h2>
                            <span>@Model.Autoridades.Count entidades</span>
                        </div>
                        <div class="table-responsive">
                            <table class="stats-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Autoridad</th>
                                        <th>Cantidad</th>
                                        <th>%</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Autoridades)
                                    {
                                        <tr>
                                            <td><span class="rank-badge">@item.Orden</span></td>
                                            <td>@item.Nombre</td>
                                            <td class="text-highlight">@item.Cantidad</td>
                                            <td>
                                                @item.Porcentaje%
                                                <div class="percentage-bar">
                                                    <div class="percentage-fill" style="width: @item.Porcentaje%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Frecuencias -->
                    <div class="grid-item">
                        <div class="item-header">
                            <i class="fas fa-clock"></i>
                            <h2>Distribución por Frecuencia</h2>
                            <span>@Model.Frecuencias.Count tipos</span>
                        </div>
                        <div class="table-responsive">
                            <table class="stats-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Periodicidad</th>
                                        <th>Cantidad</th>
                                        <th>%</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Frecuencias)
                                    {
                                        <tr>
                                            <td><span class="rank-badge">@item.Orden</span></td>
                                            <td>@item.Nombre</td>
                                            <td class="text-highlight">@item.Cantidad</td>
                                            <td>
                                                @item.Porcentaje%
                                                <div class="percentage-bar">
                                                    <div class="percentage-fill" style="width: @item.Porcentaje%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Directores -->
                    <div class="grid-item">
                        <div class="item-header">
                            <i class="fas fa-user-tie"></i>
                            <h2>Distribución por Director</h2>
                            <span>@Model.Directores.Count responsables</span>
                        </div>
                        <div class="table-responsive">
                            <table class="stats-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Director</th>
                                        <th>Cantidad</th>
                                        <th>%</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Directores)
                                    {
                                        <tr>
                                            <td><span class="rank-badge">@item.Orden</span></td>
                                            <td>@item.Nombre</td>
                                            <td class="text-highlight">@item.Cantidad</td>
                                            <td>
                                                @item.Porcentaje%
                                                <div class="percentage-bar">
                                                    <div class="percentage-fill" style="width: @item.Porcentaje%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Temas -->
                    <div class="grid-item">
                        <div class="item-header">
                            <i class="fas fa-tags"></i>
                            <h2>Distribución por Tema</h2>
                            <span>@Model.Temas.Count categorías</span>
                        </div>
                        <div class="table-responsive">
                            <table class="stats-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Tema</th>
                                        <th>Cantidad</th>
                                        <th>%</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Temas)
                                    {
                                        <tr>
                                            <td><span class="rank-badge">@item.Orden</span></td>
                                            <td>@item.Nombre</td>
                                            <td class="text-highlight">@item.Cantidad</td>
                                            <td>
                                                @item.Porcentaje%
                                                <div class="percentage-bar">
                                                    <div class="percentage-fill" style="width: @item.Porcentaje%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Tabla de detalles de reportes -->
                <div class="grid-item full-width" style="margin-top: 0;">
                    <div class="item-header">
                        <i class="fas fa-list"></i>
                        <h2>Detalle de Reportes</h2>
                        <span>@Model.Reportes.Count registros mostrados</span>
                    </div>
                    <div class="table-responsive">
                        <table class="details-table">
                            <thead>
                                <tr>
                                    <th>Acrónimo</th>
                                    <th>Nombre del Reporte</th>
                                    <th>Autoridad</th>
                                    <th>Entidad</th>
                                    <th>Tema</th>
                                    <th>Periodicidad</th>
                                    <th>Director</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reporte in Model.Reportes)
                                {
                                    <tr>
                                        <td><span class="badge badge-blue">@reporte.Acronimo</span></td>
                                        <td>@reporte.NombreReporte</td>
                                        <td>@reporte.Autoridad</td>
                                        <td>@reporte.Entidad</td>
                                        <td>
                                            @if (reporte.Tema.Contains("Operativo"))
                                            {
                                                <span class="badge badge-blue">@reporte.Tema</span>
                                            }
                                            else if (reporte.Tema.Contains("Financiero"))
                                            {
                                                <span class="badge badge-purple">@reporte.Tema</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-green">@reporte.Tema</span>
                                            }
                                        </td>
                                        <td>@reporte.Periodicidad</td>
                                        <td>@reporte.N3Generacion</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Footer -->
                <div class="footer-note">
                    <div class="live-indicator">
                        <i class="fas fa-circle"></i>
                        <span>Sistema actualizado en tiempo real</span>
                    </div>
                    <span><i class="fas fa-shield-alt"></i> Datos confidenciales - Solo para uso autorizado</span>
                    <span><i class="fas fa-database"></i> Total: @Model.TotalReportes reportes activos</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('menuToggle').addEventListener('click', function() {
            document.getElementById('layout').classList.toggle('collapsed');
            var icon = this.querySelector('i');
            if (document.getElementById('layout').classList.contains('collapsed')) {
                icon.className = 'fas fa-chevron-right';
            } else {
                icon.className = 'fas fa-chevron-left';
            }
        });
    </script>
</body>
</html>